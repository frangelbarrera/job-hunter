# Gemini API (primary LLM)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API (fallback LLM)
GROQ_API_KEY=your_groq_api_key_here

# Gmail API credentials path (local file, not committed)
GMAIL_CREDENTIALS_PATH=~/.config/jobhunt/credentials.json
GMAIL_TOKEN_PATH=~/.config/jobhunt/token.json

# GitHub token (only for local push, NEVER commit)
# In CI, use the automatically-provided GITHUB_TOKEN secret
GH_PAT=your_github_pat_here

# Optional: profile customization
# Path to a YAML file with your profile (see profile.yaml.example)
PROFILE_PATH=profile.yaml
